struct Nave { int x; int y; int vidas; };
struct Tiro { int x; int y; bool ativo; };
struct Alien { int x; int y; bool vivo; };
struct Boss { int x; int y; int hp; bool vivo; int direcao; };

#define MAX_TIROS_JOGADOR 4
#define QTD_ALIENS_LINHAS 4
#define QTD_ALIENS_COLUNAS 5
#define TOTAL_ALIENS (QTD_ALIENS_LINHAS * QTD_ALIENS_COLUNAS)

Nave jogador;
Tiro tirosJogador[MAX_TIROS_JOGADOR];
Alien aliens[TOTAL_ALIENS];
Boss boss;
Tiro tiroAlien;

int score = 0;
int fase = 1;

// Variáveis de Controle de Estado do Jogo
bool aguardandoInicio = true; 
bool jogoAtivo = false;       

int direcaoAliens = 1;     
int velocidadeAliens = 2;
int chanceTiroAlien = 50; 

int direcaoNave = 0; 
unsigned long tempoUltimoComando = 0;

unsigned long ultimoFrame = 0;
const int frameDelay = 33; 

// Prototipagem das funções
void mostrarTelaInicial();
void inicializarJogo();
void iniciarFase();
void lerEntradas();
void atualizarJogo();
void renderizarJogo();
void verificarColisoes();
void desenharFundoGalaxia();

void setup() {
  Serial.begin(115200);
  tft.init();
  tft.setRotation(0); 
  
  // Alterado para false conforme solicitado
  tft.invertDisplay(false); 
  
  // Limpa a tela e exibe a Tela de Título do jogo
  mostrarTelaInicial();
}

void loop() {
  if (millis() - ultimoFrame >= frameDelay) {
    ultimoFrame = millis();
    
    // ESTADO 1: TELA INICIAL (Aguardando Start)
    if (aguardandoInicio) {
      if (Serial.available() > 0) {
        char cmd = tolower(Serial.read());
        if (cmd == 'w' || cmd == ' ') {
          aguardandoInicio = false;
          jogoAtivo = true;
          inicializarJogo(); // Dá o pontapé inicial no jogo
        }
      }
    } 
    // ESTADO 2: JOGANDO
    else if (jogoAtivo) {
      lerEntradas();
      atualizarJogo();
      verificarColisoes();
      renderizarJogo();
    } 
    // ESTADO 3: GAME OVER OU VITÓRIA
    else {
      if (fase > 4) {
        tft.setTextColor(TFT_GREEN, TFT_BLACK);
        tft.drawCentreString("VITORIA EPICA!", LARGURA_TELA / 2, ALTURA_TELA / 2 - 20, 4);
      } else {
        tft.setTextColor(TFT_RED, TFT_BLACK);
        tft.drawCentreString("GAME OVER", LARGURA_TELA / 2, ALTURA_TELA / 2 - 20, 4);
      }
      tft.setTextColor(TFT_WHITE, TFT_BLACK);
      tft.drawCentreString("Envie 'W' para reiniciar", LARGURA_TELA / 2, ALTURA_TELA / 2 + 20, 2);
      
      // Aguarda comando para jogar novamente
      if (Serial.available() > 0) {
        char cmd = tolower(Serial.read());
        if (cmd == 'w' || cmd == ' ') {
          inicializarJogo();
          jogoAtivo = true;
        }
      }
    }
  }
}

void mostrarTelaInicial() {
  tft.fillScreen(TFT_BLACK);
  desenharFundoGalaxia();
  
  tft.setTextColor(TFT_GREEN, TFT_BLACK);
  tft.drawCentreString("SPACE INVADERS", LARGURA_TELA / 2, ALTURA_TELA / 2 - 30, 4);
  
  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.drawCentreString("Pressione 'W' ou Espaco", LARGURA_TELA / 2, ALTURA_TELA / 2 + 20, 2);
  tft.drawCentreString("para comecar", LARGURA_TELA / 2, ALTURA_TELA / 2 + 40, 2);
  
  Serial.println("Aguardando comando (W ou Espaco) para iniciar...");
}

void desenharFundoGalaxia() {
  for (int i = 0; i < 60; i++) {
    int x = random(0, LARGURA_TELA);
    int y = random(0, ALTURA_TELA);
    uint16_t cor = TFT_WHITE;
    int tipo = random(0, 3);
    if(tipo == 1) cor = tft.color565(100, 200, 255); 
    if(tipo == 2) cor = tft.color565(200, 100, 255); 
    tft.drawPixel(x, y, cor);
  }
}

void inicializarJogo() {
  score = 0;
  fase = 1;
  jogador.vidas = 3;
  iniciarFase();
}

void iniciarFase() {
  tft.fillScreen(TFT_BLACK);
  desenharFundoGalaxia(); 
  
  jogador.x = (LARGURA_TELA - 24) / 2;
  jogador.y = ALTURA_TELA - 25; 
  direcaoNave = 0;

  for (int i = 0; i < MAX_TIROS_JOGADOR; i++) tirosJogador[i].ativo = false;
  tiroAlien.ativo = false;
  
  if (fase <= 3) {
    if (fase == 1) { velocidadeAliens = 2; chanceTiroAlien = 45; }
    if (fase == 2) { velocidadeAliens = 3; chanceTiroAlien = 30; }
    if (fase == 3) { velocidadeAliens = 4; chanceTiroAlien = 15; }
    
    int index = 0;
    for (int l = 0; l < QTD_ALIENS_LINHAS; l++) {
      for (int c = 0; c < QTD_ALIENS_COLUNAS; c++) {
        aliens[index].x = 10 + c * 40; 
        aliens[index].y = 35 + l * 26;
        aliens[index].vivo = true;
        index++;
      }
    }
    
    tft.setTextColor(TFT_YELLOW, TFT_BLACK);
    tft.drawCentreString("FASE " + String(fase), LARGURA_TELA / 2, ALTURA_TELA / 2, 4);
    delay(1500);
    tft.fillScreen(TFT_BLACK);
    desenharFundoGalaxia();
    
  } else if (fase == 4) {
    velocidadeAliens = 3;
    chanceTiroAlien = 8; 
    
    boss.x = LARGURA_TELA / 2 - 16;
    boss.y = 30;
    boss.hp = 50; 
    boss.vivo = true;
    boss.direcao = 1;
    
    tft.setTextColor(TFT_RED, TFT_BLACK);
    tft.drawCentreString("ALERTA: CHEFAO!", LARGURA_TELA / 2, ALTURA_TELA / 2, 4);
    delay(2000);
    tft.fillScreen(TFT_BLACK);
    desenharFundoGalaxia();
  }
}

void lerEntradas() {
  while (Serial.available() > 0) {
    char comando = Serial.read(); // Lemos o char original sem converter para minúscula ainda
    tempoUltimoComando = millis();
    
    // VERIFICAÇÃO PARA AS SETINHAS (Códigos ANSI que começam com ESC = 27)
    if (comando == 27) {
      delay(2); // Pequena pausa para garantir que os próximos bytes chegaram na porta Serial
      if (Serial.available() >= 2) {
        char colchete = Serial.read();
        char direcaoSeta = Serial.read();
        
        if (colchete == '[') {
          if (direcaoSeta == 'D') direcaoNave = -1;      // Seta Esquerda
          else if (direcaoSeta == 'C') direcaoNave = 1;  // Seta Direita
        }
      }
    } 
    // VERIFICAÇÃO PARA TECLAS NORMAIS (A, D, W, Espaço)
    else {
      comando = tolower(comando);
      if (comando == 'a') direcaoNave = -1;
      else if (comando == 'd') direcaoNave = 1;
      else if (comando == 'w' || comando == ' ') {
        for (int i = 0; i < MAX_TIROS_JOGADOR; i++) {
          if (!tirosJogador[i].ativo) {
            tirosJogador[i].x = jogador.x + 10; 
            tirosJogador[i].y = jogador.y - 4;
            tirosJogador[i].ativo = true;
            break; 
          }
        }
      }
    }
  }
  
  if (millis() - tempoUltimoComando > 150) direcaoNave = 0;
}

void atualizarJogo() {
  if (direcaoNave != 0) {
    int velNave = 6;
    jogador.x += direcaoNave * velNave;
    
    if (jogador.x < 0) { jogador.x = 0; direcaoNave = 0; }
    if (jogador.x > LARGURA_TELA - 24) { jogador.x = LARGURA_TELA - 24; direcaoNave = 0; }
    
    if (direcaoNave > 0) tft.fillRect(jogador.x - velNave, jogador.y, velNave, 16, TFT_BLACK);
    else if (direcaoNave < 0) tft.fillRect(jogador.x + 24, jogador.y, velNave, 16, TFT_BLACK);
  }

  for (int i = 0; i < MAX_TIROS_JOGADOR; i++) {
    if (tirosJogador[i].ativo) {
      tirosJogador[i].y -= 10; 
      if (tirosJogador[i].y < 0) {
        tft.fillRect(tirosJogador[i].x, 0, 4, 15, TFT_BLACK); 
        tirosJogador[i].ativo = false;
      }
    }
  }
  
  if (fase <= 3) {
    bool alcancouBorda = false;
    for (int i = 0; i < TOTAL_ALIENS; i++) {
      if (aliens[i].vivo) {
        aliens[i].x += direcaoAliens * velocidadeAliens;
        
        if (direcaoAliens > 0) tft.fillRect(aliens[i].x - velocidadeAliens, aliens[i].y, velocidadeAliens, 16, TFT_BLACK);
        else tft.fillRect(aliens[i].x + 24, aliens[i].y, velocidadeAliens, 16, TFT_BLACK);
        
        if (aliens[i].x > LARGURA_TELA - 26 || aliens[i].x < 2) alcancouBorda = true;
      }
    }
    
    if (alcancouBorda) {
      direcaoAliens = -direcaoAliens;
      for (int i = 0; i < TOTAL_ALIENS; i++) {
        if (aliens[i].vivo) {
          tft.fillRect(aliens[i].x, aliens[i].y, 24, 16, TFT_BLACK); 
          aliens[i].y += 16;
          if (aliens[i].y >= jogador.y - 12) jogoAtivo = false;
        }
      }
    }
    
    if (!tiroAlien.ativo && random(0, chanceTiroAlien) == 5) {
      int alienSorteado = random(0, TOTAL_ALIENS);
      if (aliens[alienSorteado].vivo) {
        tiroAlien.x = aliens[alienSorteado].x + 10;
        tiroAlien.y = aliens[alienSorteado].y + 16;
        tiroAlien.ativo = true;
      }
    }
    
  } else if (fase == 4) {
    if (boss.vivo) {
      boss.x += boss.direcao * velocidadeAliens;
      
      if (boss.direcao > 0) tft.fillRect(boss.x - velocidadeAliens, boss.y, velocidadeAliens, 16, TFT_BLACK);
      else tft.fillRect(boss.x + 32, boss.y, velocidadeAliens, 16, TFT_BLACK);
      
      if (boss.x > LARGURA_TELA - 34 || boss.x < 2) boss.direcao = -boss.direcao;
      
      if (!tiroAlien.ativo && random(0, chanceTiroAlien) == 5) {
        tiroAlien.x = boss.x + 14;
        tiroAlien.y = boss.y + 16;
        tiroAlien.ativo = true;
      }
    }
  }
  
  if (tiroAlien.ativo) {
    tiroAlien.y += 8;
    if (tiroAlien.y > ALTURA_TELA) {
      tft.fillRect(tiroAlien.x, ALTURA_TELA - 15, 4, 15, TFT_BLACK);
      tiroAlien.ativo = false;
    }
  }
}

void verificarColisoes() {
  for (int i = 0; i < MAX_TIROS_JOGADOR; i++) {
    if (tirosJogador[i].ativo) {
      if (fase <= 3) {
        for (int j = 0; j < TOTAL_ALIENS; j++) {
          if (aliens[j].vivo) {
            if (tirosJogador[i].x + 4 >= aliens[j].x && tirosJogador[i].x <= aliens[j].x + 24 &&
                tirosJogador[i].y >= aliens[j].y && tirosJogador[i].y <= aliens[j].y + 16) {
              
              tft.fillRect(aliens[j].x, aliens[j].y, 24, 16, TFT_BLACK);
              aliens[j].vivo = false;
              
              tft.fillRect(tirosJogador[i].x, tirosJogador[i].y, 4, 12, TFT_BLACK);
              tirosJogador[i].ativo = false;
              
              score += 10;
              break;
            }
          }
        }
      } else if (fase == 4 && boss.vivo) {
        if (tirosJogador[i].x + 4 >= boss.x && tirosJogador[i].x <= boss.x + 32 &&
            tirosJogador[i].y >= boss.y && tirosJogador[i].y <= boss.y + 16) {
          
          tft.fillRect(boss.x, boss.y, 32, 16, TFT_BLACK); 
          boss.hp--;
          score += 50;
          tft.fillRect(tirosJogador[i].x, tirosJogador[i].y, 4, 12, TFT_BLACK);
          tirosJogador[i].ativo = false;
          if (boss.hp <= 0) boss.vivo = false;
        }
      }
    }
  }
  
  if (tiroAlien.ativo) {
    if (tiroAlien.x + 4 >= jogador.x && tiroAlien.x <= jogador.x + 24 &&
        tiroAlien.y + 12 >= jogador.y && tiroAlien.y <= jogador.y + 16) {
      
      tft.fillRect(tiroAlien.x, tiroAlien.y, 4, 12, TFT_BLACK);
      tiroAlien.ativo = false;
      jogador.vidas--;
      if (jogador.vidas <= 0) jogoAtivo = false;
    }
  }
  
  if (fase <= 3) {
    bool vitoriaFase = true;
    for (int i = 0; i < TOTAL_ALIENS; i++) {
      if (aliens[i].vivo) { vitoriaFase = false; break; }
    }
    if (vitoriaFase) { fase++; iniciarFase(); }
  } else if (fase == 4) {
    if (!boss.vivo) { fase++; jogoAtivo = false; } 
  }
}

void renderizarJogo() {
  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.drawString("SCORE: " + String(score), 5, 5, 2);
  
  if (fase == 4 && boss.vivo) {
    tft.setTextColor(TFT_RED, TFT_BLACK);
    tft.drawString("BOSS HP: " + String(boss.hp) + "  ", LARGURA_TELA - 90, 5, 2);
  } else {
    tft.drawString("LIVES: " + String(jogador.vidas), LARGURA_TELA - 65, 5, 2);
  }
  
  tft.drawBitmap(jogador.x, jogador.y, bitmap_nave_24x16, 24, 16, TFT_GREEN, TFT_BLACK);
  
  if (fase <= 3) {
    for (int i = 0; i < TOTAL_ALIENS; i++) {
      if (aliens[i].vivo) tft.drawBitmap(aliens[i].x, aliens[i].y, bitmap_alien_24x16, 24, 16, TFT_WHITE, TFT_BLACK);
    }
  } else if (fase == 4 && boss.vivo) {
    tft.drawBitmap(boss.x, boss.y, bitmap_boss_32x16, 32, 16, TFT_RED, TFT_BLACK);
  }
  
  for (int i = 0; i < MAX_TIROS_JOGADOR; i++) {
    if (tirosJogador[i].ativo) {
      tft.fillRect(tirosJogador[i].x, tirosJogador[i].y, 4, 12, TFT_YELLOW);
      tft.fillRect(tirosJogador[i].x, tirosJogador[i].y + 12, 4, 10, TFT_BLACK);
    }
  }
  
  if (tiroAlien.ativo) {
    tft.fillRect(tiroAlien.x, tiroAlien.y, 4, 12, TFT_RED);
    tft.fillRect(tiroAlien.x, tiroAlien.y - 8, 4, 8, TFT_BLACK);
  }
}
